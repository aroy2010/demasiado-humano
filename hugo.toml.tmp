baseURL = 'https://aroy1962.xyz/'
languageCode = 'es-PE'
title = 'Inquisiciones'
theme = 'PaperMod'

[params]
  author = 'Dr. Adriel Olórtegui Yzú'
  description = 'Reflexiones sobre la condición humana en tiempos de deshumanización.'
  ShowReadingTime = true
  ShowShareButtons = true
  ShowPostNavLinks = true
  ShowBreadCrumbs = true
  ShowCodeCopyButtons = true
  ShowWordCount = true
  disableFingerprinting = false  # ← CRÍTICO

[params.assets]
  disableHLJS = false

[params.homeInfoParams]
  Title = "Inquisiciones"
  Content = "Reflexiones sobre la condición humana."

[menu.main]  # ← SINTAXIS CORRECTA
  [[menu.main]]
    identifier = "inicio"
    name = "Inicio"
    url = "/"
    weight = 10
  [[menu.main]]
    identifier = "lecturas"
    name = "Lecturas"
    url = "/posts/"
    weight = 20
  [[menu.main]]
    identifier = "escritos"
    name = "Escritura Creativa"
    url = "/escritos_creativos/"
    weight = 30
  [[menu.main]]
    identifier = "acerca"
    name = "Acerca de"
    url = "/acerca/"
    weight = 40

# ... resto de tu config
